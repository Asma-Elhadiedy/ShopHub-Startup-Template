<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - My Shop</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/myshop.Web.styles.css" asp-append-version="true" />
    <link href="~/css/login.css" rel="stylesheet" />

</head>

<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-light border-bottom">
            <div class="container">

                <a class="navbar-brand nav-link-box home-box"
                   asp-controller="Product"
                   asp-action="Index">
                    myshop.Web
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link nav-link-box"
                               asp-controller="Product"
                               asp-action="Index">
                                Products
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-link-box"
                               asp-controller="Category"
                               asp-action="Index">
                                Categories
                            </a>
                        </li>

                    </ul>

                </div>

            </div>
        </nav>
    </header>

    <main class="container flex-grow-1 py-4">
        @RenderBody()
    </main>

    <footer class="mt-auto">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - myshop.Web
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>