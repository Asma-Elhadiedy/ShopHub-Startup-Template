@{
    var fullName = HttpContextAccessor.HttpContext.Session.GetString("FullName");
    var imageUrl = HttpContextAccessor.HttpContext.Session.GetString("ImageUrl");
    if (imageUrl == string.Empty)
    {
        imageUrl = "img/avatar5.png";
    }
}
<aside class="main-sidebar sidebar-dark-primary elevation-4">

    <a asp-area="Admin"
        asp-controller="Category"
       asp-action="Index"
       class="brand-link">
        <img src="~/img/download.png"
             class="brand-image img-circle elevation-3"
             style="opacity:.8">

        <span class="brand-text">Admin Board</span>
    </a>

    <div class="sidebar">

        <div class="user-panel mt-3 pb-3 mb-3 d-flex">
            <div class="image">
                <img src="~/@imageUrl"
                     class="img-circle elevation-2">
            </div>

            <div class="info">
                <a href="#" class="d-block">
                    User: @fullName
                </a>
            </div>
        </div>

        <nav class="mt-2">

            <ul class="nav nav-pills nav-sidebar flex-column">

@*                 <li class="nav-item" id="js-dashboardSidebar">
                    <a asp-area="Admin" asp-controller="Dashboard"
                       asp-action="Index"
                       class="nav-link">
                        <i class="nav-icon fas fa-chart-line"></i>
                        <p>Dashboard</p>
                    </a>
                </li>
 *@

            @if(User.IsInRole(ConstRoles.Admin))
            {
                <li class="nav-item" id="js-categoriesSidebar">
                    <a asp-area="Admin" 
                       asp-controller="Category"
                       asp-action="Index"
                       class="nav-link">
                        <i class="nav-icon fas fa-tags"></i>
                        <p>Categories</p>
                    </a>
                </li>

                <li class="nav-item" id="js-productsSidebar">
                    <a asp-area="Admin"
                       asp-controller="Product"
                       asp-action="Index"
                       class="nav-link">
                        <i class="nav-icon fas fa-box-open"></i>
                        <p>Products</p>
                    </a>
                </li>

                <li class="nav-item" id="js-usersSidebar">
                    <a asp-area="Admin"
                       asp-controller="User"
                       asp-action="Index"
                       class="nav-link">
                        <i class="nav-icon fas fa-user"></i>
                        <p>Users</p>
                    </a>
                </li>

            }
                <li class="nav-item" id="js-ordersSidebar">
                    <a asp-area="Admin"
                       asp-controller="Order"
                       asp-action="Index"
                       class="nav-link">
                        <i class="nav-icon fas fa-truck"></i>
                        <p>Orders</p>
                    </a>
                </li>

                <li class="nav-item">
                    <a
                       asp-area=""
                       asp-controller="Account"
                       asp-action="Logout"
                       class="nav-link">
                        <i class="nav-icon fas fa-sign-out-alt"></i>
                        <p>Logout</p>
                    </a>
                </li>

            </ul>

        </nav>

    </div>

</aside>
